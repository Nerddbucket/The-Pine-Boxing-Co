---
interface Props {
  title: string;
  accent?: 'red' | 'white';
  class?: string;
}

const { title, accent = 'white', class: className = '' } = Astro.props;
---

<div class:list={['mb-8', className]}>
  <h2
    class:list={[
      'font-display text-3xl tracking-wider md:text-4xl',
      accent === 'red' ? 'text-pines-red' : 'text-pines-white',
    ]}
  >
    {title}
  </h2>
  {accent === 'white' && (
    <div class="mt-3 h-0.5 w-16 bg-pines-red" aria-hidden="true" />
  )}
</div>
