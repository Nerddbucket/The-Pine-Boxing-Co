---
import { site } from '../../config/site';
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';
import AcuityScheduleButton from '../ui/AcuityScheduleButton.astro';
---

<section
  id="home"
  class="relative min-h-[85vh] overflow-hidden"
  aria-labelledby="hero-heading"
>
  <video
    class="absolute inset-0 h-full w-full object-cover pines-grayscale"
    src={site.hero.video}
    autoplay
    muted
    loop
    playsinline
    preload="auto"
    poster="https://images.unsplash.com/photo-1549719386-74dfcbf7dbed?w=1920&q=80"
    aria-hidden="true"
  />
  <div class="absolute inset-0 pines-image-overlay" aria-hidden="true" />

  <Container class="relative z-10 flex min-h-[85vh] items-center py-20">
    <div class="max-w-2xl">
      <h1 id="hero-heading" class="font-display leading-[0.95] tracking-wide">
        <span class="block text-4xl text-pines-white md:text-5xl lg:text-6xl">
          {site.hero.line1}
        </span>
        <span class="mt-2 block text-4xl text-pines-red md:text-5xl lg:text-6xl">
          {site.hero.line2}
        </span>
      </h1>
      <p class="mt-6 max-w-lg text-base leading-relaxed text-pines-muted md:text-lg">
        {site.hero.description}
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <Button href={site.ctas.heroPrimary.href} variant="solid-red">
          {site.ctas.heroPrimary.label}
        </Button>
        <AcuityScheduleButton label={site.ctas.heroSecondary.label} variant="ghost-white" />
      </div>
    </div>
  </Container>
</section>
