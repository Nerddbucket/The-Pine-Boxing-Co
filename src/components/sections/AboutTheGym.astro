---
import { site } from '../../config/site';
import Container from '../ui/Container.astro';
import SectionTitle from '../ui/SectionTitle.astro';
import FeatureIcon from '../ui/FeatureIcon.astro';
---

<section id="about" class="bg-pines-charcoal py-20 lg:py-28">
  <Container>
    <div class="max-w-xl">
      <SectionTitle title={site.about.title} />
      <p class="text-base leading-relaxed text-pines-muted">
        {site.about.description}
      </p>
    </div>

    <div class="mt-16 grid grid-cols-2 gap-10 sm:grid-cols-3 lg:grid-cols-6">
      {
        site.about.features.map((feature) => (
          <div class="flex flex-col items-center text-center">
            <FeatureIcon icon={feature.icon} />
            <p class="mt-4 font-display text-xs tracking-wider text-pines-white md:text-sm">
              {feature.label}
            </p>
          </div>
        ))
      }
    </div>

    <p class="mt-16 text-center font-display text-lg tracking-wider md:text-xl">
      <span class="text-pines-white">{site.about.tagline[0]} </span>
      <span class="text-pines-red">{site.about.tagline[1]}</span>
    </p>
  </Container>
</section>
