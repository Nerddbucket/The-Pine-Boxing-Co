---
import { site } from '../../config/site';
import Container from '../ui/Container.astro';
import SectionTitle from '../ui/SectionTitle.astro';
import AcuityScheduleButton from '../ui/AcuityScheduleButton.astro';

const camp = site.classes.summerCamp;
---

<section id="classes" class="bg-pines-charcoal py-20 lg:py-28">
  <Container>
    <SectionTitle title={site.classes.title} />
    <p class="mb-12 max-w-2xl text-pines-muted">{site.classes.description}</p>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        site.classes.items.map((item) => (
          <article class="border border-white/10 bg-pines-black p-6">
            <h3 class="font-display text-lg tracking-wider text-pines-red">{item.name}</h3>
            <p class="mt-3 text-sm leading-relaxed text-pines-muted">{item.description}</p>
          </article>
        ))
      }
    </div>

    <div
      id="summer-camp"
      class="mt-20 border border-pines-red/40 bg-pines-black p-8 lg:mt-24 lg:p-12"
      aria-labelledby="summer-camp-heading"
    >
      <span class="font-display text-xs tracking-widest text-pines-red">SUMMER PROGRAM</span>
      <h3 id="summer-camp-heading" class="mt-3 font-display text-2xl tracking-wider text-pines-white md:text-3xl">
        {camp.title}
      </h3>
      <p class="mt-2 font-display text-lg tracking-wide text-pines-red">{camp.tagline}</p>
      <p class="mt-6 max-w-3xl text-pines-muted">{camp.description}</p>

      <dl class="mt-8 grid gap-6 sm:grid-cols-3">
        <div>
          <dt class="font-display text-xs tracking-widest text-pines-red">AGES</dt>
          <dd class="mt-1 text-pines-white">{camp.ages}</dd>
        </div>
        <div>
          <dt class="font-display text-xs tracking-widest text-pines-red">SEASON</dt>
          <dd class="mt-1 text-pines-white">{camp.season}</dd>
        </div>
        <div>
          <dt class="font-display text-xs tracking-widest text-pines-red">SCHEDULE</dt>
          <dd class="mt-1 text-pines-white">{camp.schedule}</dd>
        </div>
      </dl>

      <ul class="mt-8 grid gap-3 sm:grid-cols-2">
        {
          camp.highlights.map((item) => (
            <li class="text-sm text-pines-muted">— {item}</li>
          ))
        }
      </ul>

      <AcuityScheduleButton label={camp.cta.label} variant="solid-red" class="mt-10" />
    </div>
  </Container>
</section>
