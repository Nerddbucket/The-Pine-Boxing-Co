---
import { site } from '../../config/site';

interface Props {
  size?: 'header' | 'footer';
}

const { size = 'header' } = Astro.props;

const sizeClasses = {
  header: 'h-20 w-20 sm:h-24 sm:w-24',
  footer: 'h-24 w-24',
};
---

<a href="#home" class="group inline-flex shrink-0" aria-label={`${site.name} home`}>
  <img
    src={site.logo.src}
    alt={site.logo.alt}
    width={96}
    height={96}
    class:list={['object-contain transition-opacity group-hover:opacity-90', sizeClasses[size]]}
    loading="eager"
    decoding="async"
  />
</a>
