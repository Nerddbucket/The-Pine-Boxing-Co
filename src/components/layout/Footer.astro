---
import { site } from '../../config/site';
import Logo from './Logo.astro';
import Container from '../ui/Container.astro';
---

<footer class="border-t border-white/10 bg-pines-black py-12">
  <Container>
    <div class="flex flex-col gap-10 md:flex-row md:items-start md:justify-between">
      <Logo size="footer" />
      <nav class="flex flex-wrap gap-6" aria-label="Footer navigation">
        {
          site.nav.map((item) => (
            <a
              href={item.href}
              class="font-display text-sm tracking-wider text-pines-muted transition-colors hover:text-pines-red"
            >
              {item.label}
            </a>
          ))
        }
      </nav>
      <div class="flex gap-4">
        <a
          href={site.social.instagram}
          class="font-display text-sm tracking-wider text-pines-muted hover:text-pines-red"
          target="_blank"
          rel="noopener noreferrer"
        >
          INSTAGRAM
        </a>
        <a
          href={site.social.facebook}
          class="font-display text-sm tracking-wider text-pines-muted hover:text-pines-red"
          target="_blank"
          rel="noopener noreferrer"
        >
          FACEBOOK
        </a>
      </div>
    </div>
    <div class="mt-10 flex flex-col gap-4 border-t border-white/10 pt-8 text-sm text-pines-muted sm:flex-row sm:justify-between">
      <p>&copy; {new Date().getFullYear()} {site.name}. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="/privacy" class="hover:text-pines-red">Privacy</a>
        <a href="/terms" class="hover:text-pines-red">Terms</a>
      </div>
    </div>
  </Container>
</footer>
