---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
---

<BaseLayout title="Privacy Policy | The Pines Boxing Co." description="Privacy policy for The Pines Boxing Co.">
  <main class="py-20">
    <Container>
      <h1 class="font-display text-4xl tracking-wider text-pines-white">PRIVACY POLICY</h1>
      <p class="mt-6 max-w-2xl text-pines-muted">
        This is a placeholder privacy policy. Replace with your client's legal copy before launch.
        Contact form submissions are processed according to your chosen form provider's terms.
      </p>
      <a href="/" class="mt-8 inline-block font-display text-pines-red hover:underline">← Back to home</a>
    </Container>
  </main>
</BaseLayout>
